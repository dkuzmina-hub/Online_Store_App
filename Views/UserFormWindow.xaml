<Window x:Class="OnlineStoreApp.Views.UserFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь"
        Height="460" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC"  Icon="/Images/app.ico">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTitle" Grid.Row="0"
                   FontSize="17" FontWeight="SemiBold" FontFamily="Segoe UI"
                   Foreground="#0F172A" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Label Content="Имя *"/>
                <TextBox x:Name="TxtName" Margin="0,0,0,14"/>

                <Label Content="Email *"/>
                <TextBox x:Name="TxtEmail" Margin="0,0,0,14"/>

                <Label Content="Пароль *"/>
                <PasswordBox x:Name="PwdPassword" Margin="0,0,0,14"/>

                <Label Content="Телефон"/>
                <TextBox x:Name="TxtPhone" Margin="0,0,0,14"/>

                <Label Content="Адрес"/>
                <TextBox x:Name="TxtAddress" Margin="0,0,0,14"/>

                <Border x:Name="PanelError" Background="#FEF2F2" CornerRadius="6"
                        BorderBrush="#FECACA" BorderThickness="1"
                        Padding="12,8" Visibility="Collapsed">
                    <TextBlock x:Name="TxtError" Foreground="#DC2626"
                               FontSize="12" TextWrapping="Wrap" FontFamily="Segoe UI"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
			<Button Content="Отмена" Style="{StaticResource BtnSecondary}"
                    Width="90" Height="36" Margin="0,0,10,0"
                    Click="BtnCancel_Click"/>
            <Button x:Name="BtnSave" Content="Сохранить"
                    Style="{StaticResource BtnPrimary}"
                    Width="100" Height="36"
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
