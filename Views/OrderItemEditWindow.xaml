<Window x:Class="OnlineStoreApp.Views.OrderItemEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактировать позицию заказа"
        Height="320" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC"  Icon="/Images/app.ico">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Редактировать позицию заказа"
                   FontSize="17" FontWeight="SemiBold" FontFamily="Segoe UI"
                   Foreground="#0F172A" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">

            <!-- Read-only info -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#F1F5F9" CornerRadius="6"
                        Padding="12,10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="ЗАКАЗ" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#64748B" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TxtOrderId" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#0F172A" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="6"
                        Padding="12,10" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="ТОВАР" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#64748B" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TxtProductName" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#0F172A" FontFamily="Segoe UI"
                                   Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Label x:Name="LblQuantity" Content="Количество *"/>
            <TextBox x:Name="TxtQuantity" Margin="0,0,0,6"/>
            <TextBlock x:Name="TxtStockHint" FontSize="11" Foreground="#64748B"
                       FontFamily="Segoe UI" Margin="0,0,0,14"/>

            <Border x:Name="PanelError" Background="#FEF2F2" CornerRadius="6"
                    BorderBrush="#FECACA" BorderThickness="1"
                    Padding="12,8" Visibility="Collapsed">
                <TextBlock x:Name="TxtError" Foreground="#DC2626"
                           FontSize="12" TextWrapping="Wrap" FontFamily="Segoe UI"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                    Width="90" Height="36" Margin="0,0,10,0"
                    Click="BtnCancel_Click"/>
            <Button Content="Сохранить" Style="{StaticResource PrimaryButton}"
                    Width="100" Height="36" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
