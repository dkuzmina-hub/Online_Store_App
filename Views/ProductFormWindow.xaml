<Window x:Class="OnlineStoreApp.Views.ProductFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар"
        Height="720" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC" Icon="/Images/app.ico">

	<Grid Margin="28">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock x:Name="TxtTitle" Grid.Row="0"
                   FontSize="17" FontWeight="SemiBold" FontFamily="Segoe UI"
                   Foreground="#0F172A" Margin="0,0,0,20"/>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
			<StackPanel>
				<Label Content="Название *"/>
				<TextBox x:Name="TxtName" Margin="0,0,0,14"/>

				<Label Content="Описание"/>
				<TextBox x:Name="TxtDescription" Margin="0,0,0,14" Height="60"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

				<Label Content="Цена (MDL) *"/>
				<TextBox x:Name="TxtPrice" Margin="0,0,0,14"/>

				<Label Content="Остаток на складе *"/>
				<TextBox x:Name="TxtStock" Margin="0,0,0,14"/>

				<Label Content="Категория *"/>
				<ComboBox x:Name="CboCategory" Margin="0,0,0,14"
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>

				<!-- === Тип размера === -->
				<Label Content="Тип размера"/>
				<ComboBox x:Name="CboSizeType" Margin="0,0,0,14"
                          SelectionChanged="CboSizeType_SelectionChanged">
					<ComboBoxItem Tag="none"     Content="Без размера"  IsSelected="True"/>
					<ComboBoxItem Tag="clothing" Content="Одежда (XS / S / M / L / XL / XXL)"/>
					<ComboBoxItem Tag="shoes"    Content="Обувь (EU: 35–46)"/>
				</ComboBox>

				<!-- === Управление размерами (скрыт по умолчанию) === -->
				<Border x:Name="PanelSizes" Visibility="Collapsed"
                        Background="#F1F5F9" CornerRadius="8"
                        BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="14" Margin="0,0,0,14">
					<StackPanel>
						<TextBlock Text="Размеры и остатки" FontSize="13" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Foreground="#0F172A" Margin="0,0,0,10"/>

						<ItemsControl x:Name="SizesList">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Grid Margin="0,0,0,6">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="70"/>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="30"/>
										</Grid.ColumnDefinitions>
										<Border Grid.Column="0" Background="White"
                                                BorderBrush="#CBD5E1" BorderThickness="1"
                                                CornerRadius="6" Padding="6,4"
                                                HorizontalAlignment="Left" Width="60">
											<TextBlock Text="{Binding Label}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       FontFamily="Segoe UI" Foreground="#1E293B"
                                                       HorizontalAlignment="Center"/>
										</Border>
										<TextBox Grid.Column="1"
                                                 Text="{Binding Stock, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="8,0,0,0" Height="28"
                                                 VerticalContentAlignment="Center"
                                                 FontFamily="Segoe UI" FontSize="13"/>
										<Button Grid.Column="2" Content="✕"
                                                Width="24" Height="24" Margin="6,0,0,0"
                                                Foreground="#EF4444" Background="Transparent"
                                                BorderThickness="0" FontSize="12"
                                                Cursor="Hand"
                                                Tag="{Binding Label}"
                                                Click="BtnRemoveSize_Click"/>
									</Grid>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<!-- Добавить новый размер -->
						<Grid Margin="0,8,0,0">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="90"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<ComboBox x:Name="CboNewSize" Grid.Column="0"
                                      Height="30" FontFamily="Segoe UI" FontSize="13"
                                      VerticalContentAlignment="Center"/>
							<TextBox x:Name="TxtNewStock" Grid.Column="1"
                                     Height="30" Margin="8,0,0,0"
                                     VerticalContentAlignment="Center"
                                     FontFamily="Segoe UI" FontSize="13"
                                     Text="0"/>
							<Button Grid.Column="2" Content="+ Добавить"
                                    Height="30" Padding="10,0" Margin="8,0,0,0"
                                    Style="{StaticResource BtnSecondary}"
                                    Click="BtnAddSize_Click"/>
						</Grid>
						<TextBlock Text="← остаток для размера" FontSize="10"
                                   Foreground="#94A3B8" FontFamily="Segoe UI"
                                   HorizontalAlignment="Right" Margin="0,2,36,0"/>
					</StackPanel>
				</Border>

				<!-- === Изображение === -->
				<Label Content="Изображение товара"/>
				<Grid Margin="0,0,0,6">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<TextBox x:Name="TxtImagePath" Grid.Column="0"
                             IsReadOnly="True" VerticalContentAlignment="Center"
                             FontSize="11" Foreground="#64748B"
                             Background="#F1F5F9"
                             Text="(не выбрано)"/>
					<Button Grid.Column="1" Content="📂 Обзор"
                            x:Name="BtnBrowseImage"
                            Click="BtnBrowseImage_Click"
                            Height="30" Padding="10,0" Margin="6,0,0,0"
                            Style="{StaticResource BtnSecondary}"/>
					<Button Grid.Column="2" Content="✕"
                            x:Name="BtnClearImage"
                            Click="BtnClearImage_Click"
                            Height="30" Width="30" Margin="4,0,0,0"
                            Foreground="#EF4444"
                            Style="{StaticResource BtnSecondary}"/>
				</Grid>

				<Border x:Name="ImgPreviewBorder"
                        Height="130" Margin="0,0,0,14"
                        Background="#F1F5F9"
                        BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="8">
					<Grid>
						<TextBlock x:Name="TxtNoImage" Text="Нет изображения"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#94A3B8" FontSize="12" FontFamily="Segoe UI"/>
						<Image x:Name="ImgPreview"
                               Stretch="Uniform"
                               MaxHeight="128"
                               Visibility="Collapsed"/>
					</Grid>
				</Border>

				<Border x:Name="PanelError" Background="#FEF2F2" CornerRadius="6"
                        BorderBrush="#FECACA" BorderThickness="1"
                        Padding="12,8" Visibility="Collapsed">
					<TextBlock x:Name="TxtError" Foreground="#DC2626"
                               FontSize="12" TextWrapping="Wrap" FontFamily="Segoe UI"/>
				</Border>
			</StackPanel>
		</ScrollViewer>

		<StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
			<Button Content="Отмена" Style="{StaticResource BtnSecondary}"
                    Width="90" Height="36" Margin="0,0,10,0"
                    Click="BtnCancel_Click"/>
			<Button Content="Сохранить" Style="{StaticResource BtnPrimary}"
                    Width="100" Height="36" Click="BtnSave_Click"/>
		</StackPanel>
	</Grid>
</Window>
