<Window x:Class="OnlineStoreApp.Views.ProductDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" Height="680" Width="860"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9" ResizeMode="CanResize" Icon="/Images/app.ico">

	<Window.Resources>
		<Style x:Key="SectionCard" TargetType="Border">
			<Setter Property="Background" Value="White"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="BorderBrush" Value="#E2E8F0"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="20"/>
			<Setter Property="Margin" Value="0,0,0,12"/>
		</Style>
		<Style x:Key="SizeBtn" TargetType="Button">
			<Setter Property="Width" Value="52"/>
			<Setter Property="Height" Value="44"/>
			<Setter Property="Margin" Value="0,0,8,8"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="FontFamily" Value="Segoe UI"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Background" Value="White"/>
			<Setter Property="Foreground" Value="#1E293B"/>
			<Setter Property="BorderBrush" Value="#CBD5E1"/>
			<Setter Property="BorderThickness" Value="1.5"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
	</Window.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="54"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Border Background="#1E293B">
			<Grid Margin="20,0">
				<TextBlock x:Name="TxtWindowTitle" Foreground="White"
                           FontSize="15" FontWeight="SemiBold" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
				<Button HorizontalAlignment="Right" Content="✕ Закрыть"
                        Background="Transparent" Foreground="#94A3B8"
                        BorderThickness="0" FontFamily="Segoe UI" FontSize="12"
                        Cursor="Hand" Click="BtnClose_Click"/>
			</Grid>
		</Border>

		<!-- Content -->
		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,20">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="300"/>
					<ColumnDefinition Width="16"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<!-- LEFT: Image + Add to cart -->
				<StackPanel Grid.Column="0">

					<!-- Product image -->
					<Border CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1"
                            Background="White" Height="260" Margin="0,0,0,12"
                            ClipToBounds="True">
						<Grid>
							<TextBlock x:Name="TxtEmoji" FontSize="72"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
							<Image x:Name="ImgProduct" Stretch="Uniform"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Visibility="Collapsed"/>
						</Grid>
					</Border>

					<!-- Price + size + quantity + cart button -->
					<Border Style="{StaticResource SectionCard}" Padding="16">
						<StackPanel>
							<TextBlock x:Name="TxtPrice"
                                       FontSize="28" FontWeight="Bold"
                                       FontFamily="Segoe UI" Foreground="#2563EB"
                                       Margin="0,0,0,4"/>
							<TextBlock x:Name="TxtStock"
                                       FontSize="12" FontFamily="Segoe UI"
                                       Foreground="#64748B" Margin="0,0,0,14"/>

							<!-- ── ВЫБОР РАЗМЕРА (скрыт для товаров без размера) ── -->
							<StackPanel x:Name="PanelSizes" Visibility="Collapsed" Margin="0,0,0,14">
								<Grid Margin="0,0,0,8">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>
									<TextBlock Text="Размер:"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#64748B" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
									<!-- Выбранный размер показывается рядом -->
									<TextBlock x:Name="TxtSelectedSize"
                                               Grid.Column="1"
                                               Text="не выбран"
                                               FontSize="12" FontWeight="Bold"
                                               FontFamily="Segoe UI"
                                               Foreground="#2563EB"
                                               VerticalAlignment="Center"/>
								</Grid>

								<!-- Кнопки размеров -->
								<WrapPanel x:Name="SizesPanel" Orientation="Horizontal"/>

								<!-- Предупреждение если не выбран -->
								<Border x:Name="PanelSizeWarn"
                                        Background="#FFF7ED" CornerRadius="6"
                                        BorderBrush="#FED7AA" BorderThickness="1"
                                        Padding="8,5" Margin="0,6,0,0"
                                        Visibility="Collapsed">
									<TextBlock Text="⚠  Выберите размер перед добавлением в корзину"
                                               FontSize="11" FontFamily="Segoe UI"
                                               Foreground="#92400E" TextWrapping="Wrap"/>
								</Border>
							</StackPanel>

							<!-- Quantity selector -->
							<TextBlock Text="Количество:" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#64748B" FontFamily="Segoe UI" Margin="0,0,0,6"/>
							<StackPanel Orientation="Horizontal" Margin="0,0,0,14">
								<Button Content="−" Width="34" Height="34"
                                        Background="#F1F5F9" BorderThickness="1"
                                        BorderBrush="#E2E8F0" FontSize="16"
                                        Cursor="Hand" Click="BtnQtyMinus_Click"/>
								<TextBox x:Name="TxtQty" Text="1" Width="50" Height="34"
                                         TextAlignment="Center" FontSize="14" FontWeight="SemiBold"
                                         VerticalContentAlignment="Center"
                                         Margin="6,0" BorderBrush="#E2E8F0"/>
								<Button Content="+" Width="34" Height="34"
                                        Background="#F1F5F9" BorderThickness="1"
                                        BorderBrush="#E2E8F0" FontSize="16"
                                        Cursor="Hand" Click="BtnQtyPlus_Click"/>
							</StackPanel>

							<Button x:Name="BtnAddCart" Content="🛒  Добавить в корзину"
                                    Style="{StaticResource PrimaryButton}"
                                    Height="42" FontSize="14"
                                    Click="BtnAddCart_Click"/>
						</StackPanel>
					</Border>

					<!-- Characteristics -->
					<Border Style="{StaticResource SectionCard}" Padding="16">
						<StackPanel>
							<TextBlock Text="Характеристики" FontSize="14" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="#0F172A" Margin="0,0,0,10"/>
							<Grid x:Name="CharGrid"/>
						</StackPanel>
					</Border>

				</StackPanel>

				<!-- RIGHT: Info + Reviews -->
				<StackPanel Grid.Column="2">

					<!-- Product info -->
					<Border Style="{StaticResource SectionCard}" Padding="20">
						<StackPanel>
							<Border x:Name="BadgeCat" CornerRadius="4" Padding="8,3"
                                    HorizontalAlignment="Left" Margin="0,0,0,8">
								<TextBlock x:Name="TxtCategory" FontSize="11"
                                           FontWeight="SemiBold" FontFamily="Segoe UI"
                                           Foreground="White"/>
							</Border>

							<TextBlock x:Name="TxtName"
                                       FontSize="22" FontWeight="Bold"
                                       FontFamily="Segoe UI" Foreground="#0F172A"
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>

							<StackPanel Orientation="Horizontal" Margin="0,0,0,12">
								<TextBlock x:Name="TxtStars" FontSize="18" Margin="0,0,6,0"/>
								<TextBlock x:Name="TxtRatingNum" FontSize="14" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="#0F172A"
                                           VerticalAlignment="Center"/>
								<TextBlock x:Name="TxtReviewCount" FontSize="12"
                                           FontFamily="Segoe UI" Foreground="#64748B"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
							</StackPanel>

							<TextBlock x:Name="TxtDesc" FontSize="13" FontFamily="Segoe UI"
                                       Foreground="#475569" TextWrapping="Wrap" LineHeight="20"/>
						</StackPanel>
					</Border>

					<!-- Reviews -->
					<Border Style="{StaticResource SectionCard}" Padding="20">
						<StackPanel>
							<Grid Margin="0,0,0,14">
								<TextBlock Text="Отзывы" FontSize="15" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="#0F172A"
                                           VerticalAlignment="Center"/>
								<Button HorizontalAlignment="Right" Content="+ Написать отзыв"
                                        Style="{StaticResource PrimaryButton}"
                                        Height="32" FontSize="12" Padding="12,0"
                                        Click="BtnWriteReview_Click"/>
							</Grid>

							<Border x:Name="PanelErr" Background="#FEF2F2" CornerRadius="6"
                                    BorderBrush="#FECACA" BorderThickness="1"
                                    Padding="10,7" Margin="0,0,0,10" Visibility="Collapsed">
								<TextBlock x:Name="TxtErr" Foreground="#DC2626" FontSize="12"
                                           TextWrapping="Wrap" FontFamily="Segoe UI"/>
							</Border>

							<StackPanel x:Name="ReviewsPanel"/>

							<Border x:Name="NoReviews" Padding="20,30" Visibility="Collapsed">
								<TextBlock Text="Отзывов пока нет. Будьте первым!"
                                           FontSize="13" Foreground="#94A3B8"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center"/>
							</Border>
						</StackPanel>
					</Border>

				</StackPanel>
			</Grid>
		</ScrollViewer>
	</Grid>
</Window>
