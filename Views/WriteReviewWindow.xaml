<Window x:Class="OnlineStoreApp.Views.WriteReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Написать отзыв" Height="380" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8FAFC"  Icon="/Images/app.ico">
<ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Написать отзыв" FontSize="17" FontWeight="SemiBold"
                       FontFamily="Segoe UI" Foreground="#0F172A"/>
            <TextBlock x:Name="TxtProductName" FontSize="12" Foreground="#64748B"
                       FontFamily="Segoe UI" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <!-- Star rating -->
            <TextBlock Text="Оценка *" FontSize="12" FontWeight="SemiBold"
                       Foreground="#64748B" FontFamily="Segoe UI" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button x:Name="Star1" Content="☆" FontSize="28" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Padding="2,0"
                        Click="Star_Click" Tag="1"
                        MouseEnter="Star_Hover" MouseLeave="Star_Leave"/>
                <Button x:Name="Star2" Content="☆" FontSize="28" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Padding="2,0"
                        Click="Star_Click" Tag="2"
                        MouseEnter="Star_Hover" MouseLeave="Star_Leave"/>
                <Button x:Name="Star3" Content="☆" FontSize="28" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Padding="2,0"
                        Click="Star_Click" Tag="3"
                        MouseEnter="Star_Hover" MouseLeave="Star_Leave"/>
                <Button x:Name="Star4" Content="☆" FontSize="28" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Padding="2,0"
                        Click="Star_Click" Tag="4"
                        MouseEnter="Star_Hover" MouseLeave="Star_Leave"/>
                <Button x:Name="Star5" Content="☆" FontSize="28" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Padding="2,0"
                        Click="Star_Click" Tag="5"
                        MouseEnter="Star_Hover" MouseLeave="Star_Leave"/>
            </StackPanel>
            <TextBlock x:Name="TxtRatingLabel" Text="Нажмите на звезду"
                       FontSize="11" Foreground="#94A3B8"
                       FontFamily="Segoe UI" Margin="0,0,0,16"/>

            <!-- Comment -->
            <TextBlock Text="Комментарий" FontSize="12" FontWeight="SemiBold"
                       Foreground="#64748B" FontFamily="Segoe UI" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtComment" Height="90" AcceptsReturn="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     MaxLength="500" Margin="0,0,0,6"/>
            <TextBlock x:Name="TxtCharCount" Text="0 / 500"
                       FontSize="11" Foreground="#94A3B8"
                       FontFamily="Segoe UI" HorizontalAlignment="Right"
                       Margin="0,0,0,10"/>

            <!-- Error -->
            <Border x:Name="PanelErr" Background="#FEF2F2" CornerRadius="6"
                    BorderBrush="#FECACA" BorderThickness="1"
                    Padding="10,7" Visibility="Collapsed">
                <TextBlock x:Name="TxtErr" Foreground="#DC2626" FontSize="12"
                           TextWrapping="Wrap" FontFamily="Segoe UI"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                    Width="88" Height="36" Margin="0,0,10,0"
                    Click="BtnCancel_Click"/>
            <Button Content="Опубликовать" Style="{StaticResource PrimaryButton}"
                    Width="120" Height="36" Click="BtnSubmit_Click"/>
        </StackPanel>
    </Grid>
 </ScrollViewer>
</Window>
