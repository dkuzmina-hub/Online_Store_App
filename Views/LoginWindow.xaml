<Window x:Class="OnlineStoreApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Online Store — Вход" Height="480" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F8FAFC"  Icon="/Images/app.ico">
	<Window.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="../Themes/Styles.xaml"/>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Window.Resources>

	<StackPanel VerticalAlignment="Center" Margin="44,0">

		<!-- Logo -->
		<Border Background="#2563EB" CornerRadius="12" Width="48" Height="48"
                HorizontalAlignment="Center" Margin="0,0,0,14">
			<TextBlock Text="🛒" FontSize="24"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
		</Border>
		<TextBlock Text="Online Store" FontSize="20" FontWeight="Bold"
                   FontFamily="Segoe UI" Foreground="#0F172A"
                   HorizontalAlignment="Center"/>
		<TextBlock Text="Войдите в свой аккаунт" FontSize="12" Foreground="#64748B"
                   FontFamily="Segoe UI" HorizontalAlignment="Center"
                   Margin="0,4,0,24"/>

		<!-- Email -->
		<Label Content="Email" FontFamily="Segoe UI" Foreground="#374151"/>
		<TextBox x:Name="TxtEmail" Margin="0,0,0,12"/>

		<!-- Password -->
		<Label Content="Пароль" FontFamily="Segoe UI" Foreground="#374151"/>
		<PasswordBox x:Name="PwdPass" Margin="0,0,0,12"/>

		<!-- Connection settings (collapsible) -->
		<Expander x:Name="ExpanderConn" Margin="0,0,0,12"
                  FontFamily="Segoe UI" FontSize="12" Foreground="#64748B"
                  Expanded="Expander_Changed" Collapsed="Expander_Changed">
			<Expander.Header>
				<StackPanel Orientation="Horizontal">
					<TextBlock x:Name="TxtConnStatus" FontSize="12"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
				</StackPanel>
			</Expander.Header>
			<StackPanel Margin="0,10,0,0">
				<Label Content="Сервер БД" FontFamily="Segoe UI" Foreground="#374151"
                       Padding="0,0,0,2"/>
				<TextBox x:Name="TxtServer" Text="localhost\SQLEXPRESS"
                         Margin="0,0,0,10"/>
				<Label Content="База данных" FontFamily="Segoe UI" Foreground="#374151"
                       Padding="0,0,0,2"/>
				<TextBox x:Name="TxtDb" Text="online_store"
                         Margin="0,0,0,10"/>
				<Button Content="Проверить подключение" Click="BtnTestConn_Click"
                        Style="{StaticResource BtnSecondary}" Height="32"
                        FontSize="12" HorizontalAlignment="Left" Padding="12,0"/>
			</StackPanel>
		</Expander>

		<!-- Error panel -->
		<Border x:Name="PanelErr" Background="#FEF2F2" CornerRadius="6"
                BorderBrush="#FECACA" BorderThickness="1"
                Padding="10,7" Margin="0,0,0,10" Visibility="Collapsed">
			<TextBlock x:Name="TxtErr" Foreground="#DC2626" FontSize="12"
                       TextWrapping="Wrap" FontFamily="Segoe UI"/>
		</Border>

		<!-- Login button -->
		<Button Content="Войти" Style="{StaticResource BtnPrimary}"
                Height="38" FontSize="14" Click="BtnLogin_Click"/>

		<!-- Register link -->
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,14,0,0">
			<TextBlock Text="Нет аккаунта? " Foreground="#64748B"
                       FontSize="12" FontFamily="Segoe UI"
                       VerticalAlignment="Center"/>
			<Button x:Name="BtnRegister" Content="Зарегистрироваться"
                    FontSize="12" FontFamily="Segoe UI" Foreground="#2563EB"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand" Click="BtnRegister_Click"/>
		</StackPanel>

	</StackPanel>
</Window>
