<Window x:Class="OnlineStoreApp.Views.BackupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Поддержка — Резервное копирование"
        Height="560" Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">

	<Grid Margin="28,24,28,24">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="20"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="16"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="16"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="12"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Заголовок -->
		<StackPanel Grid.Row="0">
			<TextBlock Text="🛡  Поддержка базы данных"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="#0F172A" FontFamily="Segoe UI"/>
			<TextBlock Text="Создание и восстановление резервных копий"
                       FontSize="12" Foreground="#64748B"
                       FontFamily="Segoe UI" Margin="0,4,0,0"/>
		</StackPanel>

		<!-- ── БЛОК: Создание бэкапа ── -->
		<Border Grid.Row="2" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="10" Padding="20,16">
			<StackPanel>
				<TextBlock Text="💾  Создать резервную копию"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#1E293B" FontFamily="Segoe UI"
                           Margin="0,0,0,10"/>

				<TextBlock x:Name="TxtSqlDataPath"
                           FontSize="11" Foreground="#64748B"
                           FontFamily="Segoe UI" Margin="0,0,0,8"
                           TextWrapping="Wrap"
                           Text="Папка SQL Server DATA: определяется автоматически..."/>

				<TextBlock Text="Имя файла резервной копии:"
                           FontSize="11" Foreground="#64748B"
                           FontFamily="Segoe UI" Margin="0,0,0,4"/>

				<Grid Margin="0,0,0,12">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="8"/>
						<ColumnDefinition Width="90"/>
					</Grid.ColumnDefinitions>
					<TextBox x:Name="TxtBackupName"
                             Grid.Column="0" Height="34"
                             FontFamily="Segoe UI" FontSize="12"
                             VerticalContentAlignment="Center"
                             Padding="8,0" BorderBrush="#CBD5E1"/>
					<Button Grid.Column="2" Content="Сохранить в…"
                            Height="34" FontSize="11"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnBrowseBackup_Click"/>
				</Grid>

				<Button x:Name="BtnBackup"
                        Content="▶  Создать резервную копию"
                        Style="{StaticResource PrimaryButton}"
                        Height="36" HorizontalAlignment="Left"
                        MinWidth="210"
                        Click="BtnBackup_Click"/>
			</StackPanel>
		</Border>

		<!-- ── БЛОК: Восстановление ── -->
		<Border Grid.Row="4" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="10" Padding="20,16">
			<StackPanel>
				<TextBlock Text="♻  Восстановить из резервной копии"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#1E293B" FontFamily="Segoe UI"
                           Margin="0,0,0,4"/>

				<TextBlock Text="⚠  Текущие данные будут заменены данными из файла."
                           FontSize="11" Foreground="#B45309"
                           FontFamily="Segoe UI" Margin="0,0,0,10"
                           TextWrapping="Wrap"/>

				<Grid Margin="0,0,0,12">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="8"/>
						<ColumnDefinition Width="90"/>
					</Grid.ColumnDefinitions>
					<TextBox x:Name="TxtRestorePath"
                             Grid.Column="0" Height="34"
                             FontFamily="Segoe UI" FontSize="12"
                             VerticalContentAlignment="Center"
                             Padding="8,0" IsReadOnly="True"
                             Background="#F8FAFC" BorderBrush="#CBD5E1"/>
					<Button Grid.Column="2" Content="Выбрать…"
                            Height="34" FontSize="11"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnBrowseRestore_Click"/>
				</Grid>

				<Button Content="♻  Восстановить базу данных"
                        Style="{StaticResource DangerButton}"
                        Height="36" HorizontalAlignment="Left"
                        MinWidth="210"
                        Click="BtnRestore_Click"/>
			</StackPanel>
		</Border>

		<!-- Заголовок лога -->
		<TextBlock Grid.Row="6" Text="Журнал операций"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="#475569" FontFamily="Segoe UI"/>

		<!-- Лог -->
		<Border Grid.Row="8" Background="#0F172A" CornerRadius="8" Padding="12,10">
			<ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="LogScroll">
				<TextBlock x:Name="TxtLog"
                           Foreground="#94A3B8"
                           FontFamily="Consolas" FontSize="11"
                           TextWrapping="Wrap"
                           Text="Готов. Нажмите «Создать резервную копию» или выберите файл для восстановления."/>
			</ScrollViewer>
		</Border>
	</Grid>
</Window>
