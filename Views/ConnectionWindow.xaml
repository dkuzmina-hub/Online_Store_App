<Window x:Class="OnlineStoreApp.Views.ConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подключение к БД" Height="400" Width="390"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F8FAFC" Icon="/Images/app.ico">
    <StackPanel Margin="32,28">
        <TextBlock Text="⚙ Настройка подключения" FontSize="16" FontWeight="SemiBold"
                   FontFamily="Segoe UI" Foreground="#0F172A" Margin="0,0,0,24"/>

        <Label Content="Сервер"/>
        <TextBox x:Name="TxtServer" Text="localhost\SQLEXPRESS" Margin="0,0,0,14"/>
        <Label Content="База данных"/>
        <TextBox x:Name="TxtDb" Text="online_store" Margin="0,0,0,14"/>
        <Label Content="Аутентификация"/>
        <ComboBox x:Name="CboAuth" Margin="0,0,0,14" SelectionChanged="CboAuth_Changed">
            <ComboBoxItem Content="Windows Authentication" IsSelected="True"/>
            <ComboBoxItem Content="SQL Server Authentication"/>
        </ComboBox>
        <StackPanel x:Name="PanelSql" Visibility="Collapsed">
            <Label Content="Логин"/>
            <TextBox x:Name="TxtLogin" Margin="0,0,0,14"/>
            <Label Content="Пароль"/>
            <PasswordBox x:Name="PwdSql" Margin="0,0,0,14"/>
        </StackPanel>

        <Border x:Name="PanelErr" Background="#FEF2F2" CornerRadius="6"
                BorderBrush="#FECACA" BorderThickness="1"
                Padding="10,7" Margin="0,0,0,12" Visibility="Collapsed">
            <TextBlock x:Name="TxtErr" Foreground="#DC2626" FontSize="12"
                       TextWrapping="Wrap" FontFamily="Segoe UI"/>
        </Border>

        <Button Content="Подключиться" Style="{StaticResource BtnPrimary}"
                Height="38" FontSize="14" Click="BtnConnect_Click"/>
    </StackPanel>
</Window>
