<Window x:Class="OnlineStoreApp.Views.SizePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор размера"
        SizeToContent="WidthAndHeight"
        MinWidth="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">

    <StackPanel Margin="24,20,24,24">

        <!-- Заголовок -->
        <TextBlock x:Name="TxtProductName"
                   Text="Выберите размер"
                   FontSize="15" FontWeight="SemiBold"
                   FontFamily="Segoe UI"
                   Foreground="#0F172A"
                   TextWrapping="Wrap"
                   Margin="0,0,0,4"/>
        <TextBlock x:Name="TxtSizeType"
                   Text=""
                   FontSize="11" Foreground="#64748B"
                   FontFamily="Segoe UI"
                   Margin="0,0,0,16"/>

        <!-- Сетка кнопок размеров -->
        <WrapPanel x:Name="SizesPanel"
                   Orientation="Horizontal"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,20"/>

        <!-- Количество -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Количество:"
                       FontSize="13" FontFamily="Segoe UI"
                       Foreground="#374151"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>
            <Button Content="−" x:Name="BtnMinus"
                    Width="32" Height="32"
                    FontSize="16"
                    Background="#E2E8F0" Foreground="#334155"
                    BorderThickness="0"
                    Click="BtnMinus_Click"/>
            <TextBlock x:Name="TxtQty"
                       Text="1" Width="40"
                       FontSize="15" FontWeight="Bold"
                       FontFamily="Segoe UI"
                       TextAlignment="Center"
                       VerticalAlignment="Center"/>
            <Button Content="+" x:Name="BtnPlus"
                    Width="32" Height="32"
                    FontSize="16"
                    Background="#2563EB" Foreground="White"
                    BorderThickness="0"
                    Click="BtnPlus_Click"/>
        </StackPanel>

        <!-- Ошибка -->
        <Border x:Name="PanelErr"
                Background="#FEF2F2" CornerRadius="6"
                BorderBrush="#FECACA" BorderThickness="1"
                Padding="10,6" Margin="0,0,0,12"
                Visibility="Collapsed">
            <TextBlock x:Name="TxtErr"
                       Foreground="#DC2626"
                       FontSize="12" FontFamily="Segoe UI"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Кнопки -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Отмена"
                    Style="{StaticResource SecondaryButton}"
                    Height="36" Click="BtnCancel_Click"/>
            <Button Grid.Column="2" Content="＋  В корзину"
                    Style="{StaticResource PrimaryButton}"
                    Height="36" Click="BtnAdd_Click"/>
        </Grid>

    </StackPanel>
</Window>
