
<Window x:Class="OnlineStoreApp.Views.ReportView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Отчёты — Online Store"
        Height="760" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9"  Icon="/Images/app.ico">

    <Window.Resources>
        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabBtnActive" TargetType="Button" BasedOn="{StaticResource TabBtn}">
            <Setter Property="Foreground" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="58"/>
			<RowDefinition Height="50"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- HEADER -->
		<Border Grid.Row="0" Background="#1E293B">
			<Grid Margin="24,0">
				<StackPanel VerticalAlignment="Center" Orientation="Horizontal">
					<TextBlock Text="📋" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
					<StackPanel VerticalAlignment="Center">
						<TextBlock Text="Отчёты FastReport" Foreground="White"
                                   FontSize="16" FontWeight="Bold" FontFamily="Segoe UI"/>
						<TextBlock Text="Печать и экспорт аналитических отчётов"
                                   Foreground="#94A3B8" FontSize="11" FontFamily="Segoe UI"/>
					</StackPanel>
				</StackPanel>
				<Button HorizontalAlignment="Right" Content="✕ Закрыть"
                        Background="Transparent" Foreground="#94A3B8"
                        BorderThickness="0" FontFamily="Segoe UI" FontSize="12"
                        Cursor="Hand" Click="BtnClose_Click"/>
			</Grid>
		</Border>

		<!-- TABS -->
		<Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
			<StackPanel Orientation="Horizontal" Margin="16,0">
				<Button x:Name="BtnTab1" Content="📋  Все заказы"
                        Style="{StaticResource TabBtnActive}" Click="BtnTab1_Click"/>
				<Button x:Name="BtnTab2" Content="🔎  Заказы с фильтром"
                        Style="{StaticResource TabBtn}" Click="BtnTab2_Click"/>
				<Button x:Name="BtnTab3" Content="📈  Продажи по категориям"
                        Style="{StaticResource TabBtn}" Click="BtnTab3_Click"/>
			</StackPanel>
		</Border>

		<!-- FILTERS (tabs 2 и 3) -->
		<Border Grid.Row="2" x:Name="PanelFilters" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="20,12" Visibility="Collapsed">
			<WrapPanel Orientation="Horizontal">
				<StackPanel Margin="0,0,12,0">
					<TextBlock Text="ДАТА С" Style="{StaticResource FilterLabel}"/>
					<DatePicker x:Name="DpFrom" Width="128" Height="34"
                                FontFamily="Segoe UI" FontSize="12"/>
				</StackPanel>
				<StackPanel Margin="0,0,16,0">
					<TextBlock Text="ДАТА ПО" Style="{StaticResource FilterLabel}"/>
					<DatePicker x:Name="DpTo" Width="128" Height="34"
                                FontFamily="Segoe UI" FontSize="12"/>
				</StackPanel>

				<!-- Статусы — только для вкладки 2 -->
				<StackPanel x:Name="PanelStatusFilters" Orientation="Horizontal">
					<StackPanel Margin="0,0,12,0">
						<TextBlock Text="СТАТУС ДОСТАВКИ" Style="{StaticResource FilterLabel}"/>
						<ComboBox x:Name="CboTrans" Width="130" Height="34" FontFamily="Segoe UI" FontSize="12">
							<ComboBoxItem Content="Все" IsSelected="True"/>
							<ComboBoxItem Content="completed"/>
							<ComboBoxItem Content="shipped"/>
							<ComboBoxItem Content="pending"/>
							<ComboBoxItem Content="cancelled"/>
						</ComboBox>
					</StackPanel>
					<StackPanel Margin="0,0,16,0">
						<TextBlock Text="СТАТУС ОПЛАТЫ" Style="{StaticResource FilterLabel}"/>
						<ComboBox x:Name="CboPaym" Width="118" Height="34" FontFamily="Segoe UI" FontSize="12">
							<ComboBoxItem Content="Все" IsSelected="True"/>
							<ComboBoxItem Content="paid"/>
							<ComboBoxItem Content="unpaid"/>
							<ComboBoxItem Content="refunded"/>
						</ComboBox>
					</StackPanel>
				</StackPanel>

				<StackPanel VerticalAlignment="Bottom">
					<Button Content="🔍  Сформировать" Style="{StaticResource PrimaryButton}"
                            Height="34" Click="BtnGenerate_Click"/>
				</StackPanel>
			</WrapPanel>
		</Border>
		<wv2:WebView2 x:Name="PdfWebView"
                      Grid.Row="3"
                      Margin="0"/>
		
	</Grid>
</Window>
