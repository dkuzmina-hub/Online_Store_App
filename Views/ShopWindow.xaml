<Window x:Class="OnlineStoreApp.Views.ShopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Online Store — Каталог" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#F1F5F9"  Icon="/Images/app.ico"  WindowState="Maximized">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="64"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="0" x:Name="CartColumn"/>
		</Grid.ColumnDefinitions>

		<!-- ══ HEADER ══ -->
		<Border Grid.Row="0" Grid.ColumnSpan="2" Background="#1E293B">
			<Grid Margin="24,0">
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<TextBlock Text="🛒" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
					<TextBlock Text="Online Store" Foreground="White" FontSize="16"
                               FontWeight="SemiBold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
				</StackPanel>
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
					<Border Background="#334155" CornerRadius="20" Padding="12,6" Margin="0,0,12,0">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="👤 " FontSize="13"/>
							<TextBlock x:Name="TxtUser" Foreground="White" FontSize="13"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"/>
						</StackPanel>
					</Border>
					<!-- Cart toggle button -->
					<Button x:Name="BtnCart" Click="BtnCart_Click"
                            Height="36" Padding="14,0" Margin="0,0,10,0"
                            Background="#2563EB" Foreground="White"
                            FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand">
						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border Background="{TemplateBinding Background}" CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
									<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter Property="Background" Value="#1D4ED8"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Button.Template>
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="🛒 Корзина" VerticalAlignment="Center"/>
							<Border x:Name="CartBadge" Background="#EF4444" CornerRadius="10"
                                    Margin="8,0,0,0" Padding="6,1" Visibility="Collapsed">
								<TextBlock x:Name="TxtCartCount" Text="0" Foreground="White"
                                           FontSize="11" FontWeight="Bold" FontFamily="Segoe UI"/>
							</Border>
						</StackPanel>
					</Button>
					<Button Content="Мои заказы" Click="BtnMyOrders_Click"
                            Height="36" Padding="14,0" Margin="0,0,10,0"
                            Style="{StaticResource BtnSecondary}"/>
					<Button Content="Выйти" Style="{StaticResource BtnSecondary}"
                            Height="36" Padding="14,0" Click="BtnLogout_Click"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- ══ FILTERS ══ -->
		<Border Grid.Row="1" Grid.Column="0" Background="White" BorderBrush="#E2E8F0"
                BorderThickness="0,0,0,1" Padding="24,12">
			<StackPanel Orientation="Horizontal">
				<TextBox x:Name="TxtSearch"  TextChanged="TxtSearch_TextChanged" Width="240" Height="36" Margin="0,0,10,0"/>
				<ComboBox x:Name="CboCat" Width="160" Margin="0,0,10,0"/>
				<Button Content="Найти"    Style="{StaticResource BtnPrimary}"
                        Height="36" Margin="0,0,8,0" Click="BtnSearch_Click"/>
				<Button Content="Сбросить" Style="{StaticResource BtnSecondary}"
                        Height="36" Click="BtnReset_Click"/>
				<TextBlock x:Name="TxtCount" VerticalAlignment="Center"
                           Margin="16,0,0,0" Foreground="#64748B"
                           FontSize="12" FontFamily="Segoe UI"/>
			</StackPanel>
		</Border>

		<!-- ══ PRODUCT CARDS ══ -->
		<ScrollViewer Grid.Row="2" Grid.Column="0"
                      VerticalScrollBarVisibility="Auto" Padding="20,16,20,20">
			<WrapPanel x:Name="CardsPanel" Orientation="Horizontal"/>
		</ScrollViewer>

		<!-- ══ CART SIDEBAR ══ -->
		<Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="1"
                Background="White" BorderBrush="#E2E8F0" BorderThickness="1,0,0,0">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<!-- Cart header -->
				<Border Grid.Row="0" Background="#1E293B" Padding="20,16">
					<Grid>
						<TextBlock Text="🛒  Корзина" Foreground="White"
                                   FontSize="15" FontWeight="SemiBold" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
						<Button Content="✕" HorizontalAlignment="Right"
                                Click="BtnCloseCart_Click"
                                Background="Transparent" Foreground="#94A3B8"
                                BorderThickness="0" FontSize="16" Cursor="Hand"
                                VerticalAlignment="Center"/>
					</Grid>
				</Border>

				<!-- Cart items list -->
				<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
					<StackPanel x:Name="CartPanel" Margin="0,8,0,0"/>
				</ScrollViewer>

				<!-- Cart footer -->
				<Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                        Padding="20,16">
					<StackPanel>
						<Grid Margin="0,0,0,6">
							<TextBlock Text="Итого:" FontFamily="Segoe UI"
                                       FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
							<TextBlock x:Name="TxtTotal" HorizontalAlignment="Right"
                                       FontSize="20" FontWeight="Bold" FontFamily="Segoe UI"
                                       Foreground="#2563EB" VerticalAlignment="Center"/>
						</Grid>
						<TextBlock x:Name="TxtItemsCount" FontSize="11"
                                   Foreground="#94A3B8" FontFamily="Segoe UI" Margin="0,0,0,14"/>
						<Button Content="✔  Оформить заказ" Click="BtnCheckout_Click"
                                Height="44" FontSize="14" FontWeight="SemiBold"
                                Background="#16A34A" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontFamily="Segoe UI">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border Background="{TemplateBinding Background}"
                                            CornerRadius="10" Padding="0,0,0,0">
										<ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter Property="Background" Value="#15803D"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Button.Template>
						</Button>
						<Button Content="Очистить корзину" Click="BtnClearCart_Click"
                                Margin="0,8,0,0" Height="34" FontSize="12"
                                Background="Transparent" Foreground="#EF4444"
                                BorderBrush="#FECACA" BorderThickness="1"
                                FontFamily="Segoe UI" Cursor="Hand">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
										<ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
									</Border>
								</ControlTemplate>
							</Button.Template>
						</Button>
					</StackPanel>
				</Border>
			</Grid>
		</Border>
	</Grid>
</Window>
