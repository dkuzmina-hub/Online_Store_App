<Window x:Class="OnlineStoreApp.Views.OrderItemFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить позицию в заказ"
        MinHeight="300" MinWidth="420"
        Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F8FAFC" Icon="/Images/app.ico">

	<ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
		<Grid Margin="28">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<TextBlock Grid.Row="0" Text="Новая позиция заказа"
                       FontSize="17" FontWeight="SemiBold" FontFamily="Segoe UI"
                       Foreground="#0F172A" Margin="0,0,0,20"/>

			<StackPanel Grid.Row="1">
				<Label Content="Заказ *"/>
				<ComboBox x:Name="CboOrder" Margin="0,0,0,14"
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>

				<Label Content="Товар *"/>
				<ComboBox x:Name="CboProduct" Margin="0,0,0,14"
                          DisplayMemberPath="Name" SelectedValuePath="Id"
                          SelectionChanged="CboProduct_SelectionChanged"/>

				<Label x:Name="LblStock" Content="Количество *"/>
				<TextBox x:Name="TxtQuantity" Margin="0,0,0,14" Text="1"/>

				<Border x:Name="PanelError" Background="#FEF2F2" CornerRadius="6"
                        BorderBrush="#FECACA" BorderThickness="1"
                        Padding="12,8" Visibility="Collapsed">
					<TextBlock x:Name="TxtError" Foreground="#DC2626"
                               FontSize="12" TextWrapping="Wrap" FontFamily="Segoe UI"/>
				</Border>
			</StackPanel>

			<StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,16,0,8">
				<Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                        Width="90" Height="36" Margin="0,0,10,0"
                        Click="BtnCancel_Click"/>
				<Button Content="Добавить" Style="{StaticResource SuccessButton}"
                        Width="100" Height="36" Click="BtnSave_Click"/>
			</StackPanel>
		</Grid>
	</ScrollViewer>
</Window>
