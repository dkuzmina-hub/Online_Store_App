<Window x:Class="OnlineStoreApp.Views.CheckoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оформление заказа" Height="580" Width="460"
        WindowStartupLocation="CenterOwner" 
        Background="#F8FAFC"
        Icon="/Images/app.ico">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Прокручиваемый контент -->
		<ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="28,28,28,0">
			<StackPanel>

				<!-- Title -->
				<StackPanel Margin="0,0,0,20">
					<TextBlock Text="Оформление заказа" FontSize="18" FontWeight="Bold"
                               FontFamily="Segoe UI" Foreground="#0F172A"/>
					<TextBlock x:Name="TxtTotal" FontSize="13" Foreground="#64748B"
                               FontFamily="Segoe UI" Margin="0,4,0,0"/>
				</StackPanel>

				<!-- Payment method toggle -->
				<Border Background="White" CornerRadius="10"
                        BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="16" Margin="0,0,0,16">
					<StackPanel>
						<TextBlock Text="Способ оплаты" FontSize="13" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Foreground="#0F172A" Margin="0,0,0,12"/>

						<!-- Cash option -->
						<Border x:Name="BdrCash" CornerRadius="8" BorderThickness="2"
                                BorderBrush="#2563EB" Background="#EFF6FF"
                                Padding="14,12" Margin="0,0,0,8" Cursor="Hand"
                                MouseLeftButtonUp="SelectCash_Click">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<TextBlock Text="💵" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0"/>
								<StackPanel Grid.Column="1" VerticalAlignment="Center">
									<TextBlock Text="При получении" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="#0F172A"/>
									<TextBlock Text="Оплата наличными курьеру" FontSize="11"
                                               FontFamily="Segoe UI" Foreground="#64748B"/>
								</StackPanel>
								<Ellipse x:Name="DotCash" Grid.Column="2" Width="18" Height="18"
                                         Fill="#2563EB" VerticalAlignment="Center"/>
							</Grid>
						</Border>

						<!-- Card option -->
						<Border x:Name="BdrCard" CornerRadius="8" BorderThickness="2"
                                BorderBrush="#E2E8F0" Background="White"
                                Padding="14,12" Cursor="Hand"
                                MouseLeftButtonUp="SelectCard_Click">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<TextBlock Text="💳" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0"/>
								<StackPanel Grid.Column="1" VerticalAlignment="Center">
									<TextBlock Text="Банковская карта" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="#0F172A"/>
									<TextBlock Text="Visa, Mastercard, Maestro" FontSize="11"
                                               FontFamily="Segoe UI" Foreground="#64748B"/>
								</StackPanel>
								<Ellipse x:Name="DotCard" Grid.Column="2" Width="18" Height="18"
                                         Fill="#E2E8F0" VerticalAlignment="Center"/>
							</Grid>
						</Border>
					</StackPanel>
				</Border>

				<!-- Card form -->
				<Border x:Name="PanelCardForm"
                        Background="White" CornerRadius="10"
                        BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="16" Margin="0,0,0,16"
                        Visibility="Collapsed">
					<StackPanel>
						<TextBlock Text="Данные карты" FontSize="13" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Foreground="#0F172A" Margin="0,0,0,14"/>

						<Label Content="Номер карты *"/>
						<Grid Margin="0,0,0,12">
							<TextBox x:Name="TxtCardNumber" MaxLength="19"
                                     FontSize="15" FontWeight="SemiBold" Padding="10,8"
                                     TextChanged="CardNumber_TextChanged"/>
							<TextBlock Text="•••• •••• •••• ••••" FontSize="13"
                                       Foreground="#CBD5E1" Margin="12,0,0,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False"
                                       x:Name="CardPlaceholder"/>
						</Grid>

						<Label Content="Имя владельца *"/>
						<TextBox x:Name="TxtCardHolder" Margin="0,0,0,12"
                                 CharacterCasing="Upper" MaxLength="26"/>

						<Grid Margin="0,0,0,12">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="16"/>
								<ColumnDefinition Width="110"/>
							</Grid.ColumnDefinitions>
							<StackPanel Grid.Column="0">
								<Label Content="Срок действия *"/>
								<TextBox x:Name="TxtExpiry" MaxLength="5"
                                         TextChanged="Expiry_TextChanged"/>
							</StackPanel>
							<StackPanel Grid.Column="2">
								<Label Content="CVV *"/>
								<PasswordBox x:Name="PwdCvv" MaxLength="3"/>
							</StackPanel>
						</Grid>

						<StackPanel Orientation="Horizontal" Margin="0,4,0,0">
							<Border Background="#1A1F71" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
								<TextBlock Text="VISA" Foreground="White" FontSize="11"
                                           FontWeight="Bold" FontFamily="Segoe UI"/>
							</Border>
							<Border Background="#EB001B" CornerRadius="4" Padding="6,4" Margin="0,0,2,0">
								<Ellipse Width="14" Height="14" Fill="#EB001B"/>
							</Border>
							<Border Background="#F79E1B" CornerRadius="4" Padding="4,4" Margin="-6,0,0,0">
								<Ellipse Width="14" Height="14" Fill="#F79E1B" Opacity="0.8"/>
							</Border>
							<TextBlock Text="Mastercard" Foreground="#64748B" FontSize="11"
                                       FontFamily="Segoe UI" VerticalAlignment="Center" Margin="6,0,0,0"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- Cash info panel -->
				<Border x:Name="PanelCashInfo"
                        Background="#F0FDF4" CornerRadius="10"
                        BorderBrush="#BBF7D0" BorderThickness="1"
                        Padding="16" Margin="0,0,0,16">
					<StackPanel>
						<TextBlock Text="✓  Заказ будет создан со статусом «не оплачен»"
                                   FontSize="12" FontFamily="Segoe UI" Foreground="#16A34A"
                                   Margin="0,0,0,6"/>
						<TextBlock Text="✓  Оплата производится курьеру при получении"
                                   FontSize="12" FontFamily="Segoe UI" Foreground="#16A34A"
                                   Margin="0,0,0,6"/>
						<TextBlock Text="✓  Доставка по всей Молдове"
                                   FontSize="12" FontFamily="Segoe UI" Foreground="#16A34A"/>
					</StackPanel>
				</Border>

			</StackPanel>
		</ScrollViewer>

		<!-- Кнопки — всегда видны внизу -->
		<StackPanel Grid.Row="1" Margin="28,10,28,24">

			<Border x:Name="PanelErr" Background="#FEF2F2" CornerRadius="6"
                    BorderBrush="#FECACA" BorderThickness="1"
                    Padding="10,7" Margin="0,0,0,10" Visibility="Collapsed">
				<TextBlock x:Name="TxtErr" Foreground="#DC2626" FontSize="12"
                           TextWrapping="Wrap" FontFamily="Segoe UI"/>
			</Border>

			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="8"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>
				<Button Grid.Column="0" Content="Отмена"
                        Style="{StaticResource SecondaryButton}"
                        Height="42" Click="BtnCancel_Click"/>
				<Button Grid.Column="2" x:Name="BtnConfirm"
                        Content="✓  Оформить заказ"
                        Style="{StaticResource PrimaryButton}"
                        Height="42" FontSize="14" FontWeight="SemiBold"
                        Click="BtnConfirm_Click"/>
			</Grid>
		</StackPanel>
	</Grid>
</Window>
